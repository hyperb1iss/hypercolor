# Hypercolor USB device permissions
# Install: just udev-install
# Grants access to the physically logged-in user via systemd-logind (TAG+="uaccess").
# A replug or reboot is required after installation for existing devices.
#
# hidraw rules use ATTRS (walk up to parent USB device for vendor/product match).
# usb rules use ATTR + DEVTYPE filter to match the /dev/bus/usb/ device node directly.

# ─── Razer ────────────────────────────────────────────────────────────────────

# Razer Huntsman V2
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1532", ATTRS{idProduct}=="026c", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="1532", ATTR{idProduct}=="026c", TAG+="uaccess"

# Razer Basilisk V3
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1532", ATTRS{idProduct}=="0099", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="1532", ATTR{idProduct}=="0099", TAG+="uaccess"

# Razer Seiren Emote
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1532", ATTRS{idProduct}=="0f1b", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="1532", ATTR{idProduct}=="0f1b", TAG+="uaccess"

