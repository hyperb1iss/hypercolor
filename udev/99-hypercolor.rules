# ─── Dygma ────────────────────────────────────────────────────────────────────

# Dygma Defy (Wired)
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="35ef", ATTRS{idProduct}=="0010", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="35ef", ATTR{idProduct}=="0010", TAG+="uaccess"

# Dygma Defy (Wireless) — also needs serial/ttyACM access
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="35ef", ATTRS{idProduct}=="0012", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="35ef", ATTR{idProduct}=="0012", TAG+="uaccess"
SUBSYSTEM=="tty", ATTRS{idVendor}=="35ef", ATTRS{idProduct}=="0012", TAG+="uaccess"
