# ─── Input event nodes ────────────────────────────────────────────────────────
# Host keyboard/mouse capture lives in 70-hypercolor-input.rules, which MUST
# sort before systemd's 73-seat-late.rules for `uaccess` to apply. See that
# file for the vendor list and the ordering rationale.

# ─── SMBus / I2C ──────────────────────────────────────────────────────────────
SUBSYSTEM=="i2c-dev", KERNEL=="i2c-[0-9]*", MODE="0660", GROUP="users", TAG+="uaccess"
