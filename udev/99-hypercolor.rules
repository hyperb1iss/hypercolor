# Hypercolor device permissions
# Install: just udev-install
# Grants access to the physically logged-in user via systemd-logind (TAG+="uaccess").
# Some hidraw nodes can miss their ACL replay on existing devices, so we also set a
# conservative fallback group/mode for the supported vendor families.
# A replug or reboot is required after installation for existing devices.
#
# USB rules are vendor-wide for the brands Hypercolor supports so newly added
# product IDs do not require a udev update just to gain device-node access.
# SMBus access is granted generically via `/dev/i2c-*` because bus nodes are
# host-controller devices, not vendor-scoped endpoints.
#
# hidraw/tty rules use ATTRS (walk up to parent USB device for vendor match).
# usb rules use ATTR + DEVTYPE filter to match the /dev/bus/usb/ device node directly.

# ─── Razer ────────────────────────────────────────────────────────────────────
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1532", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="1532", MODE="0660", GROUP="users", TAG+="uaccess"

# ─── Corsair ──────────────────────────────────────────────────────────────────
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1b1c", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="1b1c", MODE="0660", GROUP="users", TAG+="uaccess"

# ─── PrismRGB / Nollie / GCS ──────────────────────────────────────────────────
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="16d5", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="16d5", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="tty", ATTRS{idVendor}=="16d5", MODE="0660", GROUP="users", TAG+="uaccess"

SUBSYSTEM=="hidraw", ATTRS{idVendor}=="16d1", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="16d1", MODE="0660", GROUP="users", TAG+="uaccess"

SUBSYSTEM=="hidraw", ATTRS{idVendor}=="16d2", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="16d2", MODE="0660", GROUP="users", TAG+="uaccess"

SUBSYSTEM=="hidraw", ATTRS{idVendor}=="16d3", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="16d3", MODE="0660", GROUP="users", TAG+="uaccess"

SUBSYSTEM=="hidraw", ATTRS{idVendor}=="3061", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="3061", MODE="0660", GROUP="users", TAG+="uaccess"

SUBSYSTEM=="hidraw", ATTRS{idVendor}=="16d0", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="16d0", MODE="0660", GROUP="users", TAG+="uaccess"

# ─── Dygma ────────────────────────────────────────────────────────────────────
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="35ef", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="35ef", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="tty", ATTRS{idVendor}=="35ef", MODE="0660", GROUP="users", TAG+="uaccess"

# ─── ASUS Aura ────────────────────────────────────────────────────────────────
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0b05", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="0b05", MODE="0660", GROUP="users", TAG+="uaccess"

# ─── Lian Li ──────────────────────────────────────────────────────────────────
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0416", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="0416", MODE="0660", GROUP="users", TAG+="uaccess"

SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="0cf2", MODE="0660", GROUP="users", TAG+="uaccess"

# ─── Ableton ──────────────────────────────────────────────────────────────────
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="2982", MODE="0660", GROUP="users", TAG+="uaccess"

# ─── QMK community implementation keyboards ───────────────────────────────────────────────
# Keychron
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="3434", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="3434", MODE="0660", GROUP="users", TAG+="uaccess"

# ZSA (Moonlander, Voyager)
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="3297", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="3297", MODE="0660", GROUP="users", TAG+="uaccess"

# Drop / OLKB
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="feed", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="feed", MODE="0660", GROUP="users", TAG+="uaccess"

# Glorious (GMMK)
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="320f", MODE="0660", GROUP="users", TAG+="uaccess"
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="320f", MODE="0660", GROUP="users", TAG+="uaccess"

# ─── SMBus / I2C ──────────────────────────────────────────────────────────────
SUBSYSTEM=="i2c-dev", KERNEL=="i2c-[0-9]*", MODE="0660", GROUP="users", TAG+="uaccess"
