{
    "name": "@hypercolor/sdk",
    "version": "0.1.0",
    "description": "TypeScript SDK for creating Hypercolor RGB lighting effects",
    "type": "module",
    "main": "./src/index.ts",
    "module": "./src/index.ts",
    "types": "./src/index.ts",
    "bin": {
        "hypercolor": "./bin/hypercolor.js"
    },
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        }
    },
    "files": [
        "bin",
        "src",
        "dist",
        "templates"
    ],
    "scripts": {
        "build": "bun ./build-package.ts && tsc -p tsconfig.build.json",
        "dev": "bun --watch ./build-package.ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {},
    "devDependencies": {
        "@types/node": "^24.10.1",
        "bun-types": "^1.3.14",
        "tsup": "^8.5.0",
        "typescript": "^5.9.3"
    },
    "engines": {
        "bun": ">=1.2.0",
        "node": ">=24.0.0"
    },
    "keywords": [
        "hypercolor",
        "rgb",
        "lighting",
        "effects",
        "webgl",
        "shader",
        "typescript",
        "canvas"
    ],
    "author": "Stefanie Jane <stef@hyperbliss.tech>",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/hyperb1iss/hypercolor",
        "directory": "sdk/packages/core"
    }
}
