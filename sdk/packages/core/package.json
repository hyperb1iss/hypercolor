{
    "name": "@hypercolor/sdk",
    "version": "0.1.0",
    "description": "TypeScript SDK for creating Hypercolor RGB lighting effects",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "reflect-metadata": "^0.2.2"
    },
    "devDependencies": {
        "tsup": "^8.5.0",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=24.0.0"
    },
    "keywords": [
        "hypercolor",
        "rgb",
        "lighting",
        "effects",
        "webgl",
        "shader",
        "typescript",
        "decorators"
    ],
    "author": "Stefanie Jane <stef@hyperbliss.tech>",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/hyperb1iss/hypercolor",
        "directory": "sdk/packages/core"
    }
}
