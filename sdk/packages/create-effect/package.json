{
    "name": "@hypercolor/create-effect",
    "version": "0.1.0",
    "description": "Bun create scaffolder for Hypercolor effect workspaces",
    "type": "module",
    "main": "./src/index.ts",
    "module": "./src/index.ts",
    "types": "./src/index.ts",
    "bin": {
        "create-hypercolor-effect": "./bin/create-hypercolor-effect.js"
    },
    "exports": {
        ".": {
            "import": "./src/index.ts",
            "types": "./src/index.ts"
        }
    },
    "files": [
        "bin",
        "src",
        "templates"
    ],
    "scripts": {
        "build": "tsc --noEmit",
        "dev": "tsc --noEmit --watch",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@clack/prompts": "^1.4.0"
    },
    "devDependencies": {
        "@types/node": "^25.7.0",
        "bun-types": "^1.3.14",
        "typescript": "^6.0.3"
    },
    "engines": {
        "bun": ">=1.2.0",
        "node": ">=24.0.0"
    },
    "keywords": [
        "hypercolor",
        "rgb",
        "lighting",
        "bun",
        "scaffolding"
    ],
    "author": "Stefanie Jane <stef@hyperbliss.tech>",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/hyperb1iss/hypercolor",
        "directory": "sdk/packages/create-effect"
    }
}
