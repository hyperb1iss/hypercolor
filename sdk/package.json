{
    "name": "hypercolor-sdk",
    "private": true,
    "workspaces": ["packages/*"],
    "scripts": {
        "build": "bun run --filter '*' build",
        "dev": "bun run --filter '*' dev",
        "check": "biome check --write .",
        "lint": "biome lint --write .",
        "format": "biome format --write .",
        "typecheck": "bun run --filter '*' typecheck",
        "clean": "rm -rf packages/*/dist",
        "build:effects": "bun scripts/build-effect.ts --all",
        "build:effect": "bun scripts/build-effect.ts"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.8",
        "esbuild": "^0.27.3",
        "typescript": "^5.9.3"
    },
    "dependencies": {}
}
