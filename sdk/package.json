{
    "name": "hypercolor-sdk",
    "private": true,
    "workspaces": ["packages/*"],
    "scripts": {
        "build": "bun run --filter '*' build",
        "dev": "bun run --filter '*' dev",
        "check": "biome check .",
        "check:fix": "biome check --write .",
        "lint": "biome lint .",
        "lint:fix": "biome lint --write .",
        "format": "biome format --write .",
        "typecheck": "bun run --filter '*' typecheck && tsc --noEmit -p tsconfig.json",
        "clean": "rm -rf packages/*/dist",
        "build:effects": "bun scripts/build-effect.ts --all",
        "build:effect": "bun scripts/build-effect.ts",
        "build:faces": "bun scripts/build-effect.ts --faces"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.6",
        "esbuild": "^0.27.3",
        "typescript": "^5.9.3"
    },
    "dependencies": {}
}
