# Hypercolor Python client commands

set dotenv-load := false

[private]
default:
    @just --list

# Sync project dependencies
sync:
    uv sync

# Run Ruff lint checks
lint:
    uv run ruff check .

# Apply Ruff lint fixes and formatting
fix:
    uv run ruff check --fix .
    uv run ruff format .

# Check Ruff formatting
fmt-check:
    uv run ruff format --check .

# Format Python sources
fmt:
    uv run ruff format .

# Type-check with ty
typecheck:
    uv run ty check

# Generate the vendored OpenAPI client
generate *args='':
    uv run python scripts/generate_openapi_client.py {{ args }}

# Verify the vendored OpenAPI client is current
generate-check:
    uv run python scripts/generate_openapi_client.py --check

# Generate Python WebSocket protocol constants
ws-protocol-generate:
    uv run python scripts/generate_ws_protocol.py

# Verify Python WebSocket protocol constants are current
ws-protocol-check:
    uv run python scripts/generate_ws_protocol.py --check

# Run pytest
test:
    uv run pytest

# Run the full Python verification suite
verify: lint fmt-check typecheck ws-protocol-check test
    @echo '✅ Python checks passed'
