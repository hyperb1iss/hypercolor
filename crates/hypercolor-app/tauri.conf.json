{
  "productName": "Hypercolor",
  "version": "0.1.0",
  "identifier": "tech.hyperbliss.hypercolor",
  "app": {
    "windows": [],
    "security": {}
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "category": "Utility",
    "shortDescription": "RGB lighting orchestration",
    "longDescription": "Hypercolor is an open-source RGB lighting orchestration engine for Linux, Windows, and macOS.",
    "licenseFile": "../../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/ui/": "ui/",
      "resources/effects/bundled/": "effects/bundled/",
      "resources/tools/": "tools/"
    },
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English"]
      },
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "dmg": {
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    }
  }
}
